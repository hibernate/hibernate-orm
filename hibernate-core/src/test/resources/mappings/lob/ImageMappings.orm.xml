<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
				 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
				 version="7.0">
	<package>org.hibernate.orm.test.lob</package>

	<entity class="LongByteArrayHolder" metadata-complete="true" access="FIELD">
		<table name="LOB_ENTITY_IMAGE"/>
		<attributes>
			<id name="id">
				<column name="ID"/>
				<generated-value/>
			</id>
			<basic name="longByteArray">
				<column name="LONG_BYTE_ARRAY" length="17000"/>
				<jdbc-type-code>-4</jdbc-type-code>
			</basic>
		</attributes>
	</entity>
</entity-mappings>
