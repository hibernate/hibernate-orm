<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
				 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
				 version="7.0">
	<package>org.hibernate.orm.test.lob</package>

	<entity class="LongStringHolder" metadata-complete="true" access="FIELD">
		<table name="LOB_ENTITY_MAT_CLOB"/>
		<attributes>
			<id name="id">
				<column name="ID"/>
				<generated-value/>
			</id>
			<basic name="longString">
				<column name="LONG_STR" length="15000"/>
				<lob/>
			</basic>
		</attributes>
	</entity>
</entity-mappings>
