<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 version="8.0">
    <entity class="org.hibernate.orm.test.boot.models.xml.attr.ElementCollectionTests$SimpleEntity" metadata-complete="true" access="FIELD">
        <attributes>
            <id name="id"/>
            <element-collection name="data" classification="MAP">
                <map-key-column name="data_key"/>
                <map-key-jdbc-type-code>12</map-key-jdbc-type-code>
                <column name="data_value"/>
                <collection-table name="entity_data">
                    <join-column name="entity_id"/>
                </collection-table>
            </element-collection>
        </attributes>
    </entity>
</entity-mappings>
