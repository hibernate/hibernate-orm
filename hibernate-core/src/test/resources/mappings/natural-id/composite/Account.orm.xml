<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.naturalid.composite.Account"
            access="FIELD" metadata-complete="true">
        <table name="accounts"/>
        <attributes>
            <embedded-id name="accountId"/>
            <natural-id mutable="true">
                <basic name="shortCode">
                    <column name="short_code" nullable="false"/>
                </basic>
            </natural-id>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.mapping.naturalid.composite.AccountId"
                access="FIELD" metadata-complete="true">
        <attributes>
            <basic name="id"/>
        </attributes>
    </embeddable>

</entity-mappings>
