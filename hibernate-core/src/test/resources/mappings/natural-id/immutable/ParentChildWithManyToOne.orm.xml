<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.naturalid.immutable.Parent"
            access="FIELD" metadata-complete="true">
        <table name="Parent"/>
        <attributes>
            <id name="id"/>
            <basic name="name"/>
            <one-to-many name="children"
                         target-entity="org.hibernate.orm.test.mapping.naturalid.immutable.Child"
                         mapped-by="parent"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.mapping.naturalid.immutable.Child"
            access="FIELD" metadata-complete="true">
        <table name="Child"/>
        <attributes>
            <id name="id"/>
            <natural-id>
                <basic name="name">
                    <column nullable="false"/>
                </basic>
                <many-to-one name="parent" optional="false"
                             target-entity="org.hibernate.orm.test.mapping.naturalid.immutable.Parent"/>
            </natural-id>
        </attributes>
    </entity>

</entity-mappings>
