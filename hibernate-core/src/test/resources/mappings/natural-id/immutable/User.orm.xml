<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.naturalid.immutable.User"
            access="PROPERTY" metadata-complete="true">
        <table name="IMM_NAT_ID_USER"/>
        <attributes>
            <id name="myUserId">
                <generated-value/>
            </id>
            <natural-id>
                <basic name="userName">
                    <column length="10" nullable="false"/>
                </basic>
            </natural-id>
            <version name="version"/>
            <basic name="password">
                <column name="`password`" nullable="false" length="15"/>
            </basic>
            <basic name="email"/>
        </attributes>
    </entity>

</entity-mappings>
