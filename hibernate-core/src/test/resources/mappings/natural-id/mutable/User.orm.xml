<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.naturalid.mutable.User"
            access="FIELD" metadata-complete="true">
        <table name="SystemUserInfo"/>
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <natural-id mutable="true">
                <basic name="name">
                    <column nullable="false"/>
                </basic>
                <basic name="org">
                    <column nullable="false"/>
                </basic>
            </natural-id>
            <basic name="password">
                <column name="`password`"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
