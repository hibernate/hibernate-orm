                    <join-column name="MAIN_ID" unique="false" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" unique="false" table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='MATERIAL' AND ASSOCIATION_CODE='RATING'</sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="ratings" target-entity="LazyManyToManyNonUniqueIdNotFoundWhereTest$Rating" fetch="LAZY" classification="SET">
                <join-table name="MATERIAL_RATINGS">
                    <join-column name="MATERIAL_ID" unique="false" table="MATERIAL_RATINGS"/>
                    <inverse-join-column name="RATING_ID" unique="false" table="MATERIAL_RATINGS"/>
                </join-table>
            </many-to-many>
        </attributes>
    </entity>
