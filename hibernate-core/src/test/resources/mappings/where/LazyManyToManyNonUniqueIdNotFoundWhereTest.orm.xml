                    <join-column name="MAIN_ID" unique="false" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" unique="false"  table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='MATERIAL' AND ASSOCIATION_CODE='SIZE'</sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="ratingsFromCombined" target-entity="LazyManyToManyNonUniqueIdNotFoundWhereTest$Rating" fetch="LAZY" classification="SET">
