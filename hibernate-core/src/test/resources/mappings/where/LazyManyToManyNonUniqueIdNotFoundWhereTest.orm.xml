    <package>org.hibernate.orm.test.where.hbm</package>
    <entity class="LazyManyToManyNonUniqueIdNotFoundWhereTest$Material" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'MATERIAL'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
            </id>
