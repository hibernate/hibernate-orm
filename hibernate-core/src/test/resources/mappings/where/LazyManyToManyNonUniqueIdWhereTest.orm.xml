<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                https://www.hibernate.org/xsd/orm/mapping/mapping-8.0.xsd"
                 version="8.0">
    <package>org.hibernate.orm.test.where.xml</package>
    <entity class="LazyManyToManyNonUniqueIdWhereTest$Material" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'MATERIAL'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" />
                <java-type>org.hibernate.type.descriptor.java.IntegerJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.IntegerJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
            </basic>
            <many-to-many name="sizesFromCombined" target-entity="LazyManyToManyNonUniqueIdWhereTest$Size" fetch="LAZY"
                          classification="SET">
                <join-table name="ASSOCIATION_TABLE">
                    <join-column name="MAIN_ID" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='MATERIAL' AND ASSOCIATION_CODE='SIZE'
                </sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="mediumOrHighRatingsFromCombined"
                          target-entity="LazyManyToManyNonUniqueIdWhereTest$Rating" fetch="LAZY" classification="BAG">
                <sql-restriction>NAME = 'high' or NAME = 'medium'</sql-restriction>
                <join-table name="ASSOCIATION_TABLE">
                    <join-column name="MAIN_ID" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='MATERIAL' AND ASSOCIATION_CODE='RATING'
                </sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="ratings" target-entity="LazyManyToManyNonUniqueIdWhereTest$Rating" fetch="LAZY"
                          classification="SET">
                <join-table name="MATERIAL_RATINGS">
                    <join-column name="MATERIAL_ID" table="MATERIAL_RATINGS"/>
                    <inverse-join-column name="RATING_ID" table="MATERIAL_RATINGS"/>
                </join-table>
            </many-to-many>
        </attributes>
    </entity>
    <entity class="LazyManyToManyNonUniqueIdWhereTest$Building" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'BUILDING'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" />
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
            </basic>
            <many-to-many name="sizesFromCombined" target-entity="LazyManyToManyNonUniqueIdWhereTest$Size" fetch="LAZY"
                          classification="SET">
                <join-table name="ASSOCIATION_TABLE">
                    <join-column name="MAIN_ID" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='BUILDING' AND ASSOCIATION_CODE='SIZE'
                </sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="ratingsFromCombined" target-entity="LazyManyToManyNonUniqueIdWhereTest$Rating"
                          fetch="LAZY" classification="SET">
                <join-table name="ASSOCIATION_TABLE">
                    <join-column name="MAIN_ID" table="ASSOCIATION_TABLE"/>
                    <inverse-join-column name="ASSOCIATION_ID" table="ASSOCIATION_TABLE"/>
                </join-table>
                <sql-join-table-restriction>MAIN_CODE='BUILDING' AND ASSOCIATION_CODE='RATING'
                </sql-join-table-restriction>
            </many-to-many>
            <many-to-many name="mediumOrHighRatings" target-entity="LazyManyToManyNonUniqueIdWhereTest$Rating"
                          fetch="LAZY" classification="BAG">
                <sql-restriction>NAME = 'high' or NAME = 'medium'</sql-restriction>
                <join-table name="BUILDING_RATINGS">
                    <join-column name="BUILDING_ID" table="BUILDING_RATINGS"/>
                    <inverse-join-column name="RATING_ID" table="BUILDING_RATINGS"/>
                </join-table>
            </many-to-many>
        </attributes>
    </entity>
    <entity class="LazyManyToManyNonUniqueIdWhereTest$Size" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'SIZE'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" />
                <java-type>org.hibernate.type.descriptor.java.IntegerJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.IntegerJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
            </basic>
        </attributes>
    </entity>
    <entity class="LazyManyToManyNonUniqueIdWhereTest$Rating" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'RATING'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" />
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
            </basic>
        </attributes>
    </entity>
</entity-mappings>
