<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                https://www.hibernate.org/xsd/orm/mapping/mapping-8.0.xsd"
                 version="8.0">
    <package>org.hibernate.orm.test.where.xml</package>
    <entity class="LazyOneToManyNonUniqueIdWhereTest$Material" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'MATERIAL'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME"/>
            </basic>
            <one-to-many name="sizesFromCombined" target-entity="LazyOneToManyNonUniqueIdWhereTest$Size" fetch="LAZY"
                         orphan-removal="false" classification="SET" not-found="EXCEPTION">
                <join-column name="MATERIAL_OWNER_ID"/>
                <cascade/>
            </one-to-many>
            <one-to-many name="mediumOrHighRatingsFromCombined" target-entity="LazyOneToManyNonUniqueIdWhereTest$Rating"
                         fetch="LAZY" orphan-removal="false" classification="BAG" not-found="EXCEPTION">
                <sql-restriction>NAME = 'high' or NAME = 'medium'</sql-restriction>
                <join-column name="MATERIAL_OWNER_ID"/>
                <cascade/>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="LazyOneToManyNonUniqueIdWhereTest$Building" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'BUILDING'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME"/>
            </basic>
            <one-to-many name="sizesFromCombined" target-entity="LazyOneToManyNonUniqueIdWhereTest$Size" fetch="LAZY"
                         orphan-removal="false" classification="SET" not-found="EXCEPTION">
                <join-column name="BUILDING_OWNER_ID"/>
                <cascade/>
            </one-to-many>
            <one-to-many name="ratingsFromCombined" target-entity="LazyOneToManyNonUniqueIdWhereTest$Rating"
                         fetch="LAZY" orphan-removal="false" classification="SET" not-found="EXCEPTION">
                <join-column name="BUILDING_OWNER_ID"/>
                <cascade/>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="LazyOneToManyNonUniqueIdWhereTest$Size" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'SIZE'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME"/>
            </basic>
        </attributes>
    </entity>
    <entity class="LazyOneToManyNonUniqueIdWhereTest$Rating" metadata-complete="true">
        <table name="MAIN_TABLE"/>
        <sql-restriction>CODE = 'RATING'</sql-restriction>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME"/>
            </basic>
        </attributes>
    </entity>
</entity-mappings>