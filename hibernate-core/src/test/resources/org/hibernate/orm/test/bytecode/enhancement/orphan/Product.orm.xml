<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                https://www.hibernate.org/xsd/orm/mapping/mapping-8.0.xsd"
                 version="8.0">
    <package>org.hibernate.orm.test.bytecode.enhancement.orphan</package>
    <entity class="Product" metadata-complete="true">
        <table name="t_product"/>
        <attributes>
            <id name="name">
                <column name="name"/>
            </id>
            <one-to-many name="parts" target-entity="Part" fetch="EAGER" fetch-mode="JOIN" orphan-removal="true"
                         classification="SET" not-found="EXCEPTION">
                <join-column name="productName"/>
                <cascade>
                    <cascade-all/>
                    <cascade-remove/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="Part" metadata-complete="true">
        <table name="t_part"/>
        <attributes>
            <id name="name">
                <column name="name"/>
            </id>
            <basic name="description"/>
        </attributes>
    </entity>
</entity-mappings>