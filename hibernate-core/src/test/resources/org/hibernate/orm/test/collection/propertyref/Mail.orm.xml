<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.collection.propertyref</package>
    <attribute-accessor>property</attribute-accessor>
    <default-lazy>true</default-lazy>
    <entity class="Mail" metadata-complete="true">
        <table name="t_mail"/>
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value generator="id-generator"/>
                <generic-generator name="id-generator" class="native"/>
            </id>
            <basic name="alias">
                <column name="`alias`" length="20"/>
            </basic>
            <many-to-one name="user" target-entity="User" fetch="LAZY">
                <property-ref name="userid"/>
                <cascade>
                    <cascade-persist/>
                    <cascade-merge/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>
</entity-mappings>
