<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.compositeelement</package>
    <attribute-accessor>property</attribute-accessor>
    <entity class="Parent" metadata-complete="true">
        <table name="Parent"/>
        <attributes>
            <id name="id">
                <column name="parent_id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="increment"/>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
            </basic>
            <element-collection name="children" target-class="Child" fetch="LAZY" optimistic-lock="true" classification="SET">
                <mutable>true</mutable>
                <target>Child</target>
                <collection-table name="ParentChild">
                    <join-column name="parent_id" unique="false" nullable="true" insertable="true" updatable="true"/>
                </collection-table>
            </element-collection>
        </attributes>
    </entity>
    <embeddable class="Child" name="Child" access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="name" fetch="EAGER" optional="false" optimistic-lock="true">
            </basic>
            <basic name="bio" fetch="EAGER" optional="true" optimistic-lock="true">
            </basic>
            <basic name="bioLength" fetch="EAGER" optional="true" optimistic-lock="true">
                <formula>{fn length(bio)}</formula>
            </basic>
            <basic name="position" fetch="EAGER" optional="false" optimistic-lock="true">
                <column name="child_position" unique="false" nullable="false">
                    <read>child_position + 1</read>
                    <write>? - 1</write>
                </column>
            </basic>
            <parent>parent</parent>
        </attributes>
    </embeddable>
    <import class="Child" rename="Child"/>
</entity-mappings>
