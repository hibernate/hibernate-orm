<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping">
    <package>org.hibernate.orm.test.ecid</package>
    <attribute-accessor>field</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="Course" metadata-complete="true">
        <table name="SchoolCourses"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <inheritance strategy="SINGLE_TABLE"/>
        <discriminator-value>secondary/primary</discriminator-value>
        <discriminator-column name="schoolLevel" discriminator-type="STRING" force-selection="false" length="20"/>
        <attributes>
            <id name="courseCode">
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </id>
            <id name="org">
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </id>
            <basic name="description" fetch="EAGER" optional="false" optimistic-lock="true">
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
        </attributes>
    </entity>
    <entity class="UniversityCourse" metadata-complete="true">
        <extends>org.hibernate.orm.test.ecid.Course</extends>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <discriminator-value>tertiary</discriminator-value>
        <attributes>
            <basic name="semester" fetch="EAGER" optional="true" optimistic-lock="true">
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.IntegerJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.IntegerJdbcType</jdbc-type>
            </basic>
        </attributes>
    </entity>
</entity-mappings>
