<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.entityname.Vehicle"
            name="VEHICLE"
            access="PROPERTY" metadata-complete="true">
        <inheritance strategy="SINGLE_TABLE"/>
        <discriminator-value>V</discriminator-value>
        <discriminator-column name="`TYPE`" discriminator-type="STRING"/>
        <attributes>
            <id name="id" access="FIELD">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="vin"/>
            <basic name="owner"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.entityname.Car"
            name="CAR"
            access="PROPERTY" metadata-complete="true">
        <discriminator-value>C</discriminator-value>
    </entity>

    <entity class="org.hibernate.orm.test.entityname.Person"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name"/>
            <one-to-many name="cars"
                         target-entity="org.hibernate.orm.test.entityname.Vehicle"
                         classification="SET">
                <join-column name="car_id"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

</entity-mappings>
