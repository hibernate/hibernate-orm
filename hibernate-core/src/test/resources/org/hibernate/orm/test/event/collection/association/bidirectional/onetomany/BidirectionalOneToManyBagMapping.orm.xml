<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <mapped-superclass class="org.hibernate.orm.test.event.collection.AbstractParentWithCollection"
                       access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <one-to-many name="children"
                         target-entity="org.hibernate.orm.test.event.collection.association.bidirectional.onetomany.ChildWithManyToOne"
                         mapped-by="parent"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <transient name="name"/>
        </attributes>
    </mapped-superclass>

    <entity class="org.hibernate.orm.test.event.collection.association.bidirectional.onetomany.ParentWithBidirectionalOneToMany"
            access="PROPERTY" metadata-complete="true">
        <table name="PARENT"/>
    </entity>

    <mapped-superclass class="org.hibernate.orm.test.event.collection.ChildValue"
                       access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="name">
                <column name="NAME"/>
            </basic>
        </attributes>
    </mapped-superclass>

    <mapped-superclass class="org.hibernate.orm.test.event.collection.ChildEntity"
                       access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
        </attributes>
    </mapped-superclass>

    <entity class="org.hibernate.orm.test.event.collection.association.bidirectional.onetomany.ChildWithManyToOne"
            access="PROPERTY" metadata-complete="true">
        <table name="`CHILD`"/>
        <attributes>
            <many-to-one name="parent"
                         target-entity="org.hibernate.orm.test.event.collection.association.bidirectional.onetomany.ParentWithBidirectionalOneToMany">
                <join-column name="parent_id"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
