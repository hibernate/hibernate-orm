<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <mapped-superclass class="org.hibernate.orm.test.event.collection.AbstractParentWithCollection"
                       access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <many-to-many name="children"
                          target-entity="org.hibernate.orm.test.event.collection.ChildEntity"
                          classification="BAG">
                <join-table name="PARENT_CHILD">
                    <join-column name="parent_id"/>
                    <inverse-join-column name="child_id"/>
                </join-table>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-many>
            <transient name="name"/>
        </attributes>
    </mapped-superclass>

    <entity class="org.hibernate.orm.test.event.collection.association.unidirectional.ParentWithCollectionOfEntities"
            access="PROPERTY" metadata-complete="true">
        <table name="PARENT"/>
    </entity>

    <mapped-superclass class="org.hibernate.orm.test.event.collection.ChildValue"
                       access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="name">
                <column name="NAME"/>
            </basic>
        </attributes>
    </mapped-superclass>

    <entity class="org.hibernate.orm.test.event.collection.ChildEntity"
            access="PROPERTY" metadata-complete="true">
        <table name="CHILD"/>
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
        </attributes>
    </entity>

</entity-mappings>
