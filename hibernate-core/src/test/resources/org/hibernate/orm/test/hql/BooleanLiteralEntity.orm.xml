<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.BooleanLiteralEntity"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="yesNoBoolean">
                <column name="Y_N_BOOL"/>
                <convert converter="org.hibernate.type.YesNoConverter"/>
            </basic>
            <basic name="trueFalseBoolean">
                <column name="T_F_BOOL"/>
                <convert converter="org.hibernate.type.TrueFalseConverter"/>
            </basic>
            <basic name="zeroOneBoolean">
                <column name="NUM_BOOL"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
