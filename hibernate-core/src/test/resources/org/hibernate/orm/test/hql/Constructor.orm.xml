<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.Constructor"
            access="FIELD" metadata-complete="true">
        <table name="`Constructor`"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
            </id>
            <basic name="someString"/>
            <basic name="someNumber"/>
            <basic name="someBoolean"/>
            <basic name="anotherBoolean"/>
        </attributes>
    </entity>

</entity-mappings>
