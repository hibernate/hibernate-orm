<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.HeresAnotherCrazyIdFieldName"
            access="PROPERTY" metadata-complete="true">
        <table name="CRAZY_ID_NODE"/>
        <attributes>
            <id name="heresAnotherCrazyIdFieldName">
                <column name="ID"/>
                <generated-value generator="increment"/>
            </id>
            <basic name="name"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.hql.MoreCrazyIdFieldNameStuffEntity"
            access="PROPERTY" metadata-complete="true">
        <table name="CRAZY_ID_TOP"/>
        <attributes>
            <id name="moreCrazyIdFieldNameStuffEntity">
                <column name="ID"/>
                <generated-value generator="increment"/>
            </id>
            <basic name="name"/>
            <many-to-one name="heresAnotherCrazyIdFieldName"
                         target-entity="org.hibernate.orm.test.hql.HeresAnotherCrazyIdFieldName"/>
        </attributes>
    </entity>

</entity-mappings>
