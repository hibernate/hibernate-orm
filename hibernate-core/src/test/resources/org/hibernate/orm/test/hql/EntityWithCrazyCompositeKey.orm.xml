<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.EntityWithCrazyCompositeKey"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <embedded-id name="id"/>
            <basic name="name"/>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.hql.CrazyCompositeKey"
                access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="id">
                <column name="id"/>
            </basic>
            <basic name="otherId">
                <column name="other_id"/>
            </basic>
        </attributes>
    </embeddable>

</entity-mappings>
