<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.KeyManyToOneKeyEntity"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="name"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.hql.KeyManyToOneEntity"
            access="FIELD" metadata-complete="true">
        <attributes>
            <embedded-id name="id"/>
            <basic name="name"/>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.hql.KeyManyToOneEntity$Id"
                access="FIELD" metadata-complete="true">
        <attributes>
            <many-to-one name="key1"
                         target-entity="org.hibernate.orm.test.hql.KeyManyToOneKeyEntity"/>
            <basic name="key2"/>
        </attributes>
    </embeddable>

</entity-mappings>
