<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.SimpleEntityWithAssociation"
            access="PROPERTY" metadata-complete="true">
        <table name="SIMPLE_1"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value/>
            </id>
            <basic name="name">
                <column name="NAME"/>
            </basic>
            <basic name="negatedNumber">
                <column name="negated_num">
                    <read>-negated_num</read>
                    <write>0 - ?</write>
                </column>
            </basic>
            <one-to-many name="associatedEntities"
                         target-entity="org.hibernate.orm.test.hql.SimpleAssociatedEntity"
                         mapped-by="owner"
                         classification="SET">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <many-to-many name="manyToManyAssociatedEntities"
                          target-entity="org.hibernate.orm.test.hql.SimpleEntityWithAssociation"
                          classification="SET">
                <join-table name="MANY_TO_MANY">
                    <join-column name="IN_ID"/>
                    <inverse-join-column name="OUT_ID"/>
                </join-table>
                <cascade>
                    <cascade-merge/>
                    <cascade-persist/>
                </cascade>
            </many-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.hql.SimpleAssociatedEntity"
            access="PROPERTY" metadata-complete="true">
        <table name="SIMPLE_2"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value/>
            </id>
            <basic name="name">
                <column name="NAME"/>
            </basic>
            <many-to-one name="owner"
                         target-entity="org.hibernate.orm.test.hql.SimpleEntityWithAssociation">
                <join-column name="SIMPLE_1_ID"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
