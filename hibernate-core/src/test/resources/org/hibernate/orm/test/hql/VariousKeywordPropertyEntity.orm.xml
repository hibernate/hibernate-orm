<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.VariousKeywordPropertyEntity"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
            </id>
            <basic name="type">
                <column name="`type`"/>
            </basic>
            <basic name="value">
                <column name="`value`"/>
            </basic>
            <basic name="key">
                <column name="`key`"/>
            </basic>
            <basic name="entry"/>
        </attributes>
    </entity>

</entity-mappings>
