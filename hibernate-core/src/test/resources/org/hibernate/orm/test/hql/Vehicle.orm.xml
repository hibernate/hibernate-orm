<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.Vehicle"
            access="FIELD" metadata-complete="true">
        <inheritance strategy="TABLE_PER_CLASS"/>
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="vin"/>
            <basic name="owner"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.hql.Car"
            access="FIELD" metadata-complete="true"/>

    <entity class="org.hibernate.orm.test.hql.Truck"
            access="FIELD" metadata-complete="true"/>

    <entity class="org.hibernate.orm.test.hql.SUV"
            access="FIELD" metadata-complete="true"/>

    <entity class="org.hibernate.orm.test.hql.Pickup"
            access="FIELD" metadata-complete="true"/>

</entity-mappings>
