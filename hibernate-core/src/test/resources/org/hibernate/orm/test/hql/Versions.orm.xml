<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.hql.IntegerVersioned"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="name"/>
            <version name="version">
                <column name="vers"/>
            </version>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.hql.TimestampVersioned"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="name"/>
            <version name="version">
                <column name="vers"/>
                <temporal>TIMESTAMP</temporal>
            </version>
        </attributes>
    </entity>

</entity-mappings>
