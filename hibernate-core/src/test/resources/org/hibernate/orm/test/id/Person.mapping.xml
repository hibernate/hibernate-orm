<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
				 version="7.0">
	<package>org.hibernate.orm.test.id</package>
	<entity class="Person" metadata-complete="true">
		<attributes>
			<id name="id">
				<sequence-generator name="person_seq" sequence-name="product_sequence"/>
				<generated-value strategy="SEQUENCE" generator="person_seq"/>
			</id>
		</attributes>
	</entity>
</entity-mappings>
