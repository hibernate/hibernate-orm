<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.idgen.biginteger.sequence</package>
    <entity class="Entity" metadata-complete="true">
        <table name="Entity"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value strategy="SEQUENCE" generator="id-gen"/>
                <generic-generator name="id-gen" class="sequence">
                </generic-generator>
            </id>
            <basic name="name"/>
        </attributes>
    </entity>
</entity-mappings>
