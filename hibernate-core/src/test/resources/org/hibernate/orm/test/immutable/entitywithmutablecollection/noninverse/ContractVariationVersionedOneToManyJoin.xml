<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.immutable.entitywithmutablecollection.Info" access="FIELD"
            metadata-complete="true">
        <mutable>false</mutable>
        <attributes>
            <id name="id">
                <generated-value strategy="AUTO"/>
            </id>
            <basic name="text"/>
            <version name="version">
                <column name="VERS"/>
            </version>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.immutable.entitywithmutablecollection.Plan" access="FIELD"
            metadata-complete="true">
        <table name="tbl_plan"/>
        <mutable>false</mutable>
        <attributes>
            <id name="id">
                <generated-value strategy="AUTO"/>
            </id>
            <basic name="description">
                <column nullable="false"/>
            </basic>
            <version name="version">
                <column name="VERS"/>
            </version>
            <one-to-many name="infos" orphan-removal="true">
                <join-column name="col_plan"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <many-to-many name="contracts" fetch-mode="JOIN">
                <join-table name="plan_contract">
                    <join-column name="col_plan"/>
                    <inverse-join-column name="contract"/>
                </join-table>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-many>
            <transient name="owner"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.immutable.entitywithmutablecollection.Party" access="FIELD"
            metadata-complete="true">
        <mutable>false</mutable>
        <secondary-table name="contract_party" optional="true" owned="false">
            <primary-key-join-column name="party"/>
        </secondary-table>
        <attributes>
            <id name="id">
                <generated-value strategy="AUTO"/>
            </id>
            <basic name="name">
                <column nullable="false"/>
            </basic>
            <version name="version">
                <column name="VERS"/>
            </version>
            <many-to-one name="contract">
                <join-column table="contract_party" name="contract"/>
            </many-to-one>
            <one-to-many name="infos" orphan-removal="true">
                <join-column name="party"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.immutable.entitywithmutablecollection.Contract" access="FIELD"
            metadata-complete="true">
        <mutable>false</mutable>
        <attributes>
            <id name="id">
                <generated-value strategy="AUTO"/>
            </id>
            <basic name="customerName">
                <column nullable="false"/>
            </basic>
            <basic name="type">
                <column name="`type`" nullable="false"/>
            </basic>
            <version name="version">
                <column name="VERS"/>
            </version>
            <many-to-one name="parent">
                <join-column name="parent" insertable="false" updatable="false"/>
            </many-to-one>
            <one-to-many name="variations" orphan-removal="true"
                         classification="BAG" fetch-mode="JOIN">
                <order-by>id asc</order-by>
                <join-column name="contract"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <one-to-many name="subcontracts" fetch-mode="JOIN">
                <join-column name="parent"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <one-to-many name="infos" orphan-removal="true">
                <join-column name="contract"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <many-to-many name="parties">
                <join-table name="contract_party">
                    <join-column name="contract"/>
                    <inverse-join-column name="party"/>
                </join-table>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-many>
            <many-to-many name="plans" mapped-by="contracts" optimistic-lock="true"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.immutable.entitywithmutablecollection.ContractVariation" access="FIELD"
            metadata-complete="true">
        <mutable>false</mutable>
        <attributes>
            <id name="id">
                <generated-value strategy="AUTO"/>
            </id>
            <basic name="text">
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.LongVarcharJdbcType</jdbc-type>
            </basic>
            <many-to-one name="contract">
                <join-column name="contract" insertable="false" updatable="false"/>
            </many-to-one>
            <one-to-many name="infos" orphan-removal="true">
                <join-column name="contractvariation"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

</entity-mappings>
