<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.jpa.fetch.Person"
            access="PROPERTY" metadata-complete="true">
        <table name="PERSON"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="firstName"/>
            <basic name="lastName"/>
            <basic name="companyName"/>
            <one-to-many name="stays"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Stay"
                         mapped-by="person"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <one-to-many name="oldStays"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Stay"
                         mapped-by="oldPerson"
                         fetch="LAZY"
                         fetch-mode="SUBSELECT"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
            <one-to-many name="veryOldStays"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Stay"
                         mapped-by="veryOldPerson"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.jpa.fetch.Stay"
            access="PROPERTY" metadata-complete="true">
        <table name="STAY"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="startDate"/>
            <basic name="endDate"/>
            <basic name="vessel"/>
            <basic name="authoriser"/>
            <basic name="comments"/>
            <many-to-one name="person"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Person">
                <join-column name="PERS_ID"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
            <many-to-one name="oldPerson"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Person"
                         fetch="LAZY">
                <join-column name="OLD_PERS_ID"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
            <many-to-one name="veryOldPerson"
                         target-entity="org.hibernate.orm.test.jpa.fetch.Person"
                         fetch="EAGER">
                <join-column name="VERY_OLD_PERS_ID"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
