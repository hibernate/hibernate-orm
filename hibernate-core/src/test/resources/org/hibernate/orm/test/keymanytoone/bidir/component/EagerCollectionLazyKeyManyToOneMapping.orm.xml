<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
	<package>org.hibernate.orm.test.keymanytoone.bidir.component</package>

	<entity class="Customer">
		<table name="COMP_LAZY_KM2O_CUST"/>
		<attributes>
			<id name="id">
				<column name="ID"/>
				<generated-value generator="increment"/>
			</id>
			<basic name="name">
				<column name="NAME"/>
			</basic>
			<one-to-many name="orders"  mapped-by="id.customer"
						 classification="BAG" fetch="EAGER" fetch-mode="JOIN">
				<cascade>
					<cascade-all/>
				</cascade>
			</one-to-many>
		</attributes>
	</entity>

	<entity class="Order">
		<table name="COMP_LAZY_KM2O_ORDR"/>
		<attributes>
			<embedded-id name="id"/>
			<element-collection name="items">
				<column name="ITEM_DESC"/>
				<collection-table name="COMP_LAZY_KM2O_ITEM">
					<join-column name="CUST_ID" referenced-column-name="CUST_ID"/>
					<join-column name="ORDER_NUM" referenced-column-name="ORDR_NUM"/>
				</collection-table>
			</element-collection>
		</attributes>
	</entity>

	<embeddable class="Order$Id">
		<attributes>
			<basic name="number">
				<column name="ORDR_NUM"/>
			</basic>
			<many-to-one name="customer" target-entity="Customer" fetch="LAZY">
				<join-column name="CUST_ID"/>
			</many-to-one>
		</attributes>
	</embeddable>
</entity-mappings>
