<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.keymanytoone.bidir.embedded.Customer"
            access="PROPERTY" metadata-complete="true">
        <table name="EMBD_KM2O_CUST"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name">
                <column name="NAME"/>
            </basic>
            <one-to-many name="orders"
                         target-entity="org.hibernate.orm.test.keymanytoone.bidir.embedded.Order"
                         mapped-by="customer"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.keymanytoone.bidir.embedded.Order"
            access="PROPERTY" metadata-complete="true">
        <table name="EMBD_KM2O_ORDR"/>
        <attributes>
            <id name="number">
                <column name="ORDR_NUM"/>
            </id>
            <many-to-one name="customer"
                         target-entity="org.hibernate.orm.test.keymanytoone.bidir.embedded.Customer"
                         fetch="EAGER"
                         id="true">
                <join-column name="CUST_ID"/>
            </many-to-one>
            <element-collection name="items"
                                target-class="java.lang.String"
                                classification="SET">
                <column name="ITEM_DESC"/>
                <collection-table name="EMBD_KM2O_ITEM">
                    <join-column name="CUST_ID"/>
                    <join-column name="ORDER_NUM"/>
                </collection-table>
            </element-collection>
        </attributes>
    </entity>

</entity-mappings>
