<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.keymanytoone.bidir.ondelete.Customer"
            access="PROPERTY" metadata-complete="true">
        <table name="CUSTOMERS"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name">
                <column name="NAME"/>
            </basic>
            <one-to-many name="orders"
                         target-entity="org.hibernate.orm.test.keymanytoone.bidir.ondelete.Order"
                         mapped-by="customer"
                         fetch="EAGER"
                         classification="BAG">
                <on-delete>CASCADE</on-delete>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.keymanytoone.bidir.ondelete.Order"
            access="PROPERTY" metadata-complete="true">
        <table name="ORDERS"/>
        <attributes>
            <id name="number">
                <column name="ORDER_NUMBER"/>
            </id>
            <basic name="item">
                <column name="ITEM_DESCRIPTION"/>
            </basic>
            <many-to-one name="customer"
                         target-entity="org.hibernate.orm.test.keymanytoone.bidir.ondelete.Customer"
                         fetch="EAGER"
                         id="true">
                <join-column name="CUSTOMER_ID"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
