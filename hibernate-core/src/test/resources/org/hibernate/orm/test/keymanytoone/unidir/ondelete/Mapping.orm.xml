<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.keymanytoone.unidir.ondelete.Customer"
            access="PROPERTY" metadata-complete="true">
        <table name="CUSTOMERS"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name">
                <column name="NAME"/>
            </basic>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.keymanytoone.unidir.ondelete.Order"
            access="PROPERTY" metadata-complete="true">
        <table name="ORDERS"/>
        <attributes>
            <embedded-id name="id"/>
            <basic name="item">
                <column name="ITEM_DESCRIPTION"/>
            </basic>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.keymanytoone.unidir.ondelete.Order$Id"
                access="PROPERTY" metadata-complete="true">
        <attributes>
            <many-to-one name="customer"
                         target-entity="org.hibernate.orm.test.keymanytoone.unidir.ondelete.Customer"
                         fetch="EAGER">
                <join-column name="CUSTOMER_ID"/>
                <on-delete>CASCADE</on-delete>
            </many-to-one>
            <basic name="number">
                <column name="ORDER_NUMBER"/>
            </basic>
        </attributes>
    </embeddable>

</entity-mappings>
