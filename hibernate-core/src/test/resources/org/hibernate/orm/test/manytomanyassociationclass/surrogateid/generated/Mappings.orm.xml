<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.manytomanyassociationclass.User"
            access="PROPERTY" metadata-complete="true">
        <table name="HB_USER"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value/>
            </id>
            <basic name="name">
                <column name="NAME" length="40" nullable="false"/>
            </basic>
            <one-to-many name="memberships"
                         target-entity="org.hibernate.orm.test.manytomanyassociationclass.Membership"
                         mapped-by="user"
                         orphan-removal="true"
                         classification="SET">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.manytomanyassociationclass.Group"
            access="PROPERTY" metadata-complete="true">
        <table name="HB_GROUP"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value/>
            </id>
            <basic name="name">
                <column name="NAME" length="40" nullable="false"/>
            </basic>
            <one-to-many name="memberships"
                         target-entity="org.hibernate.orm.test.manytomanyassociationclass.Membership"
                         mapped-by="group"
                         orphan-removal="true"
                         classification="SET">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.manytomanyassociationclass.Membership"
            access="PROPERTY" metadata-complete="true">
        <table name="HB_MEMBERSHIP"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
            </id>
            <basic name="name">
                <column name="NAME" length="40" nullable="false"/>
            </basic>
            <many-to-one name="user"
                         target-entity="org.hibernate.orm.test.manytomanyassociationclass.User">
                <join-column name="USER_ID" nullable="false"/>
            </many-to-one>
            <many-to-one name="group"
                         target-entity="org.hibernate.orm.test.manytomanyassociationclass.Group">
                <join-column name="GROUP_ID" nullable="false"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
