<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="7.0">
    <entity name="DynamicEntity" metadata-complete="true">
        <attributes>
            <id name="id">
                <target>Integer</target>
            </id>
            <natural-id>
                <basic name="referenceCode">
                    <target>String</target>
                </basic>
            </natural-id>
            <basic name="data">
                <target>String</target>
            </basic>
        </attributes>
    </entity>
</entity-mappings>
