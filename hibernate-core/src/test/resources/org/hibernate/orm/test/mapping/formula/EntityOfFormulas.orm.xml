<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.formula.EntityOfFormulas"
            access="PROPERTY" metadata-complete="true">
        <table name="formulas"/>
        <attributes>
            <id name="id"/>
            <basic name="realValue">
                <column name="real_value"/>
            </basic>
            <basic name="stringFormula">
                <formula>{fn concat(cast(trim(cast(real_value as char(254))) as varchar(255)), ' a')}</formula>
            </basic>
            <basic name="integerFormula">
                <formula>real_value + 1</formula>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
