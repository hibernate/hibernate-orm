<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.generated.GeneratedPropertyEntity"
            access="PROPERTY" metadata-complete="true">
        <table name="gen_prop"/>
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="name"/>
            <basic name="lastModified">
                <column name="lastModified" length="8" column-definition="timestamp"/>
                <generated>ALWAYS</generated>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
