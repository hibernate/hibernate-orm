<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.mapping.inheritance.discriminator</package>
    <attribute-accessor>property</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="AccountOwner" metadata-complete="true">
        <table name="AccOwner"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="native"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <basic name="description" fetch="EAGER" optional="true" optimistic-lock="true">
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <one-to-many name="creditAccounts" target-entity="CreditAccount" fetch="LAZY" orphan-removal="false" classification="SET" not-found="EXCEPTION" optimistic-lock="true">
                <mutable>true</mutable>
                <join-column name="ownerId" unique="false" nullable="true" insertable="true" updatable="true"/>
                <cascade>
                    <cascade-persist/>
                </cascade>
            </one-to-many>
            <one-to-many name="debitAccounts" target-entity="DebitAccount" fetch="LAZY" orphan-removal="false" classification="SET" not-found="EXCEPTION" optimistic-lock="true">
                <mutable>true</mutable>
                <join-column name="ownerId" unique="false" nullable="true" insertable="true" updatable="true"/>
                <cascade>
                    <cascade-persist/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="AbstractAccount" metadata-complete="true">
        <abstract>true</abstract>
        <table name="Accounts"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>true</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <inheritance strategy="SINGLE_TABLE"/>
        <discriminator-column name="DISC" discriminator-type="STRING" force-selection="false"/>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="native"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <basic name="amount" fetch="EAGER" optional="true" optimistic-lock="true">
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.BigDecimalJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.NumericJdbcType</jdbc-type>
            </basic>
            <many-to-one name="owner" fetch="LAZY" fetch-mode="SELECT" optional="true" not-found="EXCEPTION">
                <join-column name="ownerId" unique="false" nullable="true" insertable="true" updatable="true"/>
                <cascade>
                    <cascade-persist/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>
    <entity class="CreditAccount" metadata-complete="true">
        <extends>org.hibernate.orm.test.mapping.inheritance.discriminator.AbstractAccount</extends>
        <dynamic-insert>true</dynamic-insert>
        <dynamic-update>true</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <discriminator-value>C</discriminator-value>
        <attributes/>
    </entity>
    <entity class="DebitAccount" metadata-complete="true">
        <extends>org.hibernate.orm.test.mapping.inheritance.discriminator.AbstractAccount</extends>
        <dynamic-insert>true</dynamic-insert>
        <dynamic-update>true</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <discriminator-value>D</discriminator-value>
        <attributes/>
    </entity>
</entity-mappings>
