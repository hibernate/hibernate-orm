<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.mapping.readwrite.ReadWriteEntity"
            access="PROPERTY" metadata-complete="true">
        <table name="SimpleEntity"/>
        <attributes>
            <id name="id"/>
            <basic name="name"/>
            <basic name="value">
                <column name="conv">
                    <read>conv * 1</read>
                </column>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
