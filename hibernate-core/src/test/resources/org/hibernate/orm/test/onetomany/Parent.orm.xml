<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.onetomany.Parent"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <column name="parent_id"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name"/>
            <many-to-many name="children"
                          target-entity="org.hibernate.orm.test.onetomany.Child"
                          mapped-by="parent"
                          classification="SET">
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.onetomany.Child"
            access="PROPERTY" metadata-complete="true">
        <secondary-table name="ParentChild" optional="true" owned="true">
            <primary-key-join-column name="child_id"/>
        </secondary-table>
        <attributes>
            <id name="id">
                <column name="child_id"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="name"/>
            <many-to-one name="parent"
                         target-entity="org.hibernate.orm.test.onetomany.Parent">
                <join-column name="parent_id" table="ParentChild"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
