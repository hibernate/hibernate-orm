<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.onetoone.link.Person"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="name"/>
            <basic name="dob">
                <temporal>DATE</temporal>
            </basic>
            <one-to-one name="employee"
                        target-entity="org.hibernate.orm.test.onetoone.link.Employee"
                        mapped-by="person">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-one>
            <one-to-one name="customer"
                        target-entity="org.hibernate.orm.test.onetoone.link.Customer"
                        mapped-by="person">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-one>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.onetoone.link.Employee"
            access="PROPERTY" metadata-complete="true">
        <secondary-table name="employeePerson" optional="true" owned="true">
            <primary-key-join-column name="employeeId"/>
        </secondary-table>
        <attributes>
            <id name="id">
                <column name="employeeId"/>
                <generated-value/>
            </id>
            <many-to-one name="person"
                         target-entity="org.hibernate.orm.test.onetoone.link.Person"
                         fetch="LAZY">
                <join-column name="personId" table="employeePerson" unique="true"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.onetoone.link.Customer"
            access="PROPERTY" metadata-complete="true">
        <secondary-table name="customerPerson" optional="true" owned="true">
            <primary-key-join-column name="customerId"/>
        </secondary-table>
        <attributes>
            <id name="id">
                <column name="customerId"/>
                <generated-value/>
            </id>
            <many-to-one name="person"
                         target-entity="org.hibernate.orm.test.onetoone.link.Person"
                         fetch="LAZY">
                <join-column name="personId" table="customerPerson" unique="true"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
