<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.ops</package>
    <attribute-accessor>property</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="Competition" metadata-complete="true">
        <table name="Competition"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="native"/>
                <java-type>org.hibernate.type.descriptor.java.IntegerJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.IntegerJdbcType</jdbc-type>
            </id>
            <many-to-many name="competitors" target-entity="Competitor" fetch="LAZY" classification="LIST" optimistic-lock="true">
                <order-column name="INDEX_COL"/>
                <mutable>true</mutable>
                <join-table name="COMPET_ION_OR">
                    <join-column name="TION_ID" unique="false" nullable="true" insertable="true" updatable="true" table="COMPET_ION_OR"/>
                    <inverse-join-column name="TOR_ID" unique="false" nullable="true" insertable="true" updatable="true" table="COMPET_ION_OR"/>
                </join-table>
                <cascade>
                    <cascade-persist/>
                    <cascade-merge/>
                    <cascade-remove/>
                </cascade>
            </many-to-many>
        </attributes>
    </entity>
    <entity class="Competitor" metadata-complete="true">
        <table name="Competitor"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="native"/>
                <java-type>org.hibernate.type.descriptor.java.IntegerJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.IntegerJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
        </attributes>
    </entity>
</entity-mappings>
