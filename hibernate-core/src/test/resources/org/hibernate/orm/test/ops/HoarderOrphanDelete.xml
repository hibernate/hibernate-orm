<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.ops.Item" access="FIELD">
        <attributes>
            <one-to-many name="subItemsBackref" orphan-removal="true">
                <join-column name="parentItem" nullable="false"/>
                <order-column name="indx"/>
                <cascade>
                    <cascade-persist/>
                    <cascade-merge/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.ops.Category" access="FIELD">
        <attributes>
            <one-to-many name="subCategories" orphan-removal="true">
                <join-column name="parentCategory"/>
                <cascade>
                    <cascade-persist/>
                    <cascade-merge/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

</entity-mappings>
