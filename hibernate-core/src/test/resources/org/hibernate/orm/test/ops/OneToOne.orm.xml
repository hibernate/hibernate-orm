<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.ops</package>
    <attribute-accessor>property</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="Person" metadata-complete="true">
        <table name="OPS_PERSON"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="increment"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <one-to-one name="address" target-entity="Address" fetch="EAGER" fetch-mode="JOIN" optional="true" mapped-by="resident" orphan-removal="false">
                <foreign-key/>
                <cascade/>
            </one-to-one>
            <one-to-one name="details" target-entity="PersonalDetails" fetch="EAGER" fetch-mode="JOIN" optional="true" mapped-by="person" orphan-removal="false">
                <foreign-key/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-one>
        </attributes>
    </entity>
    <entity class="Address" metadata-complete="true">
        <table name="OPS_ADDRESS"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="increment"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <basic name="streetAddress" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="STREET" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <basic name="city" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="CITY" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <basic name="country" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="CTRY" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <many-to-one name="resident" target-entity="Person" fetch="LAZY" fetch-mode="SELECT" optional="true" not-found="EXCEPTION">
                <join-column name="RESIDENT" unique="false" nullable="true" insertable="true" updatable="true"/>
                <cascade/>
            </many-to-one>
        </attributes>
    </entity>
    <entity class="PersonalDetails" metadata-complete="true">
        <table name="OPS_PERS_DETAIL"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="increment"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <basic name="somePersonalDetail" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="SOME_DETAIL" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <one-to-one name="person" target-entity="Person" fetch="LAZY" fetch-mode="SELECT" optional="false" orphan-removal="false">
                <foreign-key/>
                <cascade/>
            </one-to-one>
        </attributes>
    </entity>
</entity-mappings>
