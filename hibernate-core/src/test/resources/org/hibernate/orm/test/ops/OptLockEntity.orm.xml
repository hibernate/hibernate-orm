<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.ops</package>
    <attribute-accessor>property</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="VersionedEntity" metadata-complete="true">
        <table name="V_ENTITY"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <version name="version">
                <column name="VERS"/>
            </version>
            <many-to-one name="parent" target-entity="VersionedEntity" fetch="LAZY" fetch-mode="SELECT" optional="true" not-found="EXCEPTION">
                <join-column name="parent" unique="false" nullable="true" insertable="true" updatable="true"/>
                <cascade/>
            </many-to-one>
            <one-to-many name="children" target-entity="VersionedEntity" fetch="LAZY" mapped-by="parent" orphan-removal="false" classification="SET" not-found="EXCEPTION" optimistic-lock="true">
                <mutable>true</mutable>
                <cascade>
                    <cascade-persist/>
                    <cascade-merge/>
                    <cascade-remove/>
                    <cascade-detach/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="TimestampedEntity" metadata-complete="true">
        <table name="T_ENTITY"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="ID" unique="false" nullable="false" insertable="true" updatable="false"/>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </id>
            <basic name="name" fetch="EAGER" optional="true" optimistic-lock="true">
                <column name="NAME" unique="false" nullable="true"/>
                <generated>NEVER</generated>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
            </basic>
            <version name="timestamp">
                <column name="TS"/>
                <temporal>TIMESTAMP</temporal>
            </version>
        </attributes>
    </entity>
</entity-mappings>
