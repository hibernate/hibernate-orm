<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                 https://www.hibernate.org/xsd/orm/mapping/mapping-8.0.xsd"
                 version="8.0">
    <package>org.hibernate.orm.test.orphan.manytomany</package>
    <entity class="User" metadata-complete="true">
        <table name="`User`"/>
        <attributes>
            <id name="name">
                <column name="name" length="32"/>
            </id>
            <one-to-many name="groups" target-entity="Group" fetch="LAZY" orphan-removal="true" classification="MAP">
                <map-key-column name="groupType"/>
                <map-key-type value="Integer"/>
                <join-table name="UserGroup">
                    <join-column name="name" table="UserGroup"/>
                    <inverse-join-column name="groupName" table="UserGroup"/>
                </join-table>
            </one-to-many>
        </attributes>
    </entity>
    <entity class="Group" metadata-complete="true">
        <table name="`Group`"/>
        <attributes>
            <id name="name">
                <column name="name" length="32"/>
            </id>
            <basic name="description" fetch="EAGER" >
            </basic>
            <basic name="groupType" fetch="EAGER" >
            </basic>
        </attributes>
    </entity>
</entity-mappings>