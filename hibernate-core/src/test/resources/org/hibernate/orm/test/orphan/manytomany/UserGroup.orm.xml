<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                 https://www.hibernate.org/xsd/orm/mapping/mapping-8.0.xsd"
                 version="8.0">
    <package>org.hibernate.orm.test.orphan.manytomany</package>
    <entity class="User" metadata-complete="true">
        <table name="`User`"/>
        <attributes>
            <id name="name">
                <column name="name" length="32"/>
            </id>
            <many-to-many name="groups" target-entity="Group" fetch="LAZY" classification="MAP" orphan-removal="true">
                <map-key-column name="groupType"/>
                <map-key-type value="Integer"/>
                <join-table name="UserGroup">
                    <join-column name="name" unique="false" nullable="true" insertable="true" updatable="true"
                                 table="UserGroup"/>
                    <inverse-join-column name="groupName" unique="false" nullable="true" insertable="true"
                                         updatable="true" table="UserGroup"/>
                </join-table>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-many>
        </attributes>
    </entity>
    <entity class="Group" metadata-complete="true">
        <table name="`Group`"/>
        <attributes>
            <id name="name">
                <column name="name" length="32"/>
            </id>
            <basic name="description"/>
            <basic name="groupType"/>
        </attributes>
    </entity>
</entity-mappings>