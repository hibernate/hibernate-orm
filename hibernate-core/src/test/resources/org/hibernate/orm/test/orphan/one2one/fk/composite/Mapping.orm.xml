<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">
    <package>org.hibernate.orm.test.orphan.one2one.fk.composite</package>
    <entity class="Employee" metadata-complete="true">
        <table name="Employee"/>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="increment-generator"/>
                <generic-generator name="increment-generator" class="increment"/>
            </id>
            <one-to-one name="info" fetch="LAZY" fetch-mode="SELECT" optional="true" orphan-removal="true" >
                <join-column name="COMP_ID"/>
                <join-column name="PERS_ID"/>
                <cascade>
                    <cascade-all/>
                    <cascade-remove/>
                </cascade>
            </one-to-one>
        </attributes>
    </entity>
    <entity class="EmployeeInfo" metadata-complete="true">
        <table name="EmployeeInfo"/>
        <attributes>
            <embedded-id name="id">
                <target>EmployeeInfo$Id</target>
            </embedded-id>
        </attributes>
    </entity>
    <embeddable class="EmployeeInfo$Id" name="EmployeeInfo$Id" metadata-complete="true">
        <attributes>
            <basic name="companyId" fetch="EAGER" optional="false">
                <column name="COMP_ID" unique="false" nullable="false" insertable="true" updatable="true"/>
            </basic>
            <basic name="personId" fetch="EAGER" optional="false">
                <column name="PERS_ID" unique="false" nullable="false" insertable="true" updatable="true"/>
            </basic>
        </attributes>
    </embeddable>
</entity-mappings>