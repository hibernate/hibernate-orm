<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.orphan.one2one.pk.bidirectional.Employee"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <one-to-one name="info"
                        target-entity="org.hibernate.orm.test.orphan.one2one.pk.bidirectional.EmployeeInfo"
                        orphan-removal="true">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-one>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.orphan.one2one.pk.bidirectional.EmployeeInfo"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value generator="foreign-employee"/>
                <generic-generator name="foreign-employee" class="foreign">
                    <parameter name="property" value="employee"/>
                </generic-generator>
            </id>
            <one-to-one name="employee"
                        target-entity="org.hibernate.orm.test.orphan.one2one.pk.bidirectional.Employee"
                        constrained="true"/>
        </attributes>
    </entity>

</entity-mappings>
