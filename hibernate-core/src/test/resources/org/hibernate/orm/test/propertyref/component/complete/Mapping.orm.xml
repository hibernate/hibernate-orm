<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.propertyref.component.complete.Person"
            access="PROPERTY" metadata-complete="true">
        <table name="COMP_COMP_PROPREF_PERSON"/>
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <embedded name="identity"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.propertyref.component.complete.Account"
            access="PROPERTY" metadata-complete="true">
        <table name="COMP_COMP_PROPREF_ACCT"/>
        <attributes>
            <id name="number">
                <column name="accnum"/>
            </id>
            <many-to-one name="owner"
                         target-entity="org.hibernate.orm.test.propertyref.component.complete.Person"
                         fetch="LAZY">
                <join-column name="OWNER_NAME" referenced-column-name="name"/>
                <join-column name="OWNER_SSN" referenced-column-name="ssn"/>
            </many-to-one>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.propertyref.component.complete.Identity"
                access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="name"/>
            <basic name="ssn">
                <column name="ssn" unique="true" nullable="false"/>
            </basic>
        </attributes>
    </embeddable>

</entity-mappings>
