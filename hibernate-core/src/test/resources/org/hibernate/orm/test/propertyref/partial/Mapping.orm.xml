<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.propertyref.partial.Person"
            access="PROPERTY" metadata-complete="true">
        <table name="PART_COMP_PROPREF_PERS"/>
        <caching access="NONSTRICT_READ_WRITE"/>
        <attributes>
            <id name="id">
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <embedded name="identity"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.propertyref.partial.Account"
            access="PROPERTY" metadata-complete="true">
        <table name="PART_COMP_PROPREF_ACCT"/>
        <caching access="NONSTRICT_READ_WRITE"/>
        <attributes>
            <id name="number">
                <column name="accnum"/>
            </id>
            <many-to-one name="owner"
                         target-entity="org.hibernate.orm.test.propertyref.partial.Person"
                         fetch="LAZY">
                <property-ref name="identity.ssn"/>
            </many-to-one>
        </attributes>
    </entity>

    <embeddable class="org.hibernate.orm.test.propertyref.partial.Identity"
                access="PROPERTY" metadata-complete="true">
        <attributes>
            <basic name="name"/>
            <basic name="ssn">
                <column name="ssn" unique="true" nullable="false"/>
            </basic>
        </attributes>
    </embeddable>

</entity-mappings>
