<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.query.hhh12225.Contract"
            access="PROPERTY" metadata-complete="true">
        <table name="contract"/>
        <inheritance strategy="JOINED"/>
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="creationDate">
                <column name="creation_date" insertable="false" updatable="false"/>
                <temporal>TIMESTAMP</temporal>
                <generated>ALWAYS</generated>
            </basic>
            <basic name="modifiedDate">
                <column name="modified_date" insertable="false" updatable="false"/>
                <temporal>TIMESTAMP</temporal>
                <generated>ALWAYS</generated>
            </basic>
            <basic name="effectiveDate">
                <column name="effective_date"/>
                <temporal>TIMESTAMP</temporal>
            </basic>
            <basic name="terminationDate">
                <column name="termination_date"/>
                <temporal>TIMESTAMP</temporal>
            </basic>
            <basic name="renewalDate">
                <column name="renewal_date"/>
                <temporal>TIMESTAMP</temporal>
            </basic>
            <basic name="expiryDate">
                <column name="expiry_date"/>
                <temporal>TIMESTAMP</temporal>
            </basic>
            <version name="version"/>
            <transient name="rendered"/>
            <transient name="fixedPrice"/>
            <transient name="renewable"/>
            <transient name="emailDistributionRequested"/>
            <transient name="financedTerm"/>
            <transient name="financedAmortizationPeriod"/>
            <transient name="coverageTerm"/>
            <transient name="trackingId"/>
            <transient name="timeToCreate"/>
            <transient name="templateId"/>
            <transient name="productPrice"/>
            <transient name="totalCost"/>
            <transient name="paymentAmount"/>
            <transient name="price"/>
            <transient name="financedAmount"/>
            <transient name="coverageBenefit"/>
            <transient name="coveragePaymentRelief"/>
            <transient name="coverageFinanced"/>
            <transient name="previousDeficiency"/>
            <transient name="coverageDeficiency"/>
            <transient name="interestRate"/>
            <transient name="externalId"/>
            <transient name="paymentMethod"/>
            <transient name="paymentFrequency"/>
            <transient name="accountNumber"/>
            <transient name="origin"/>
            <transient name="premiumFinanced"/>
            <transient name="locale"/>
            <transient name="endorsed"/>
            <transient name="endorsement"/>
            <transient name="new"/>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.query.hhh12225.VehicleContract"
            access="PROPERTY" metadata-complete="true">
        <table name="contract_vehicle"/>
        <primary-key-join-column name="contract_id"/>
        <attributes>
            <one-to-many name="vehicles"
                         target-entity="org.hibernate.orm.test.query.hhh12225.Vehicle"
                         fetch="EAGER"
                         mapped-by="contract"
                         classification="BAG">
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.query.hhh12225.VehicleTrackContract"
            access="PROPERTY" metadata-complete="true">
        <table name="contract_vehicle_track"/>
        <primary-key-join-column name="contract_id"/>
        <attributes>
            <basic name="etchingId">
                <column name="etching_id" length="64"/>
            </basic>
            <basic name="original">
                <column name="original"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
