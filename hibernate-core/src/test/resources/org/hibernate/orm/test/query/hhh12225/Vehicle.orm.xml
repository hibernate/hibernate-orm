<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.query.hhh12225.Vehicle"
            access="PROPERTY" metadata-complete="true">
        <attributes>
            <id name="id">
                <generated-value/>
            </id>
            <basic name="creationDate">
                <column name="creation_date" insertable="false" updatable="false"/>
                <temporal>TIMESTAMP</temporal>
                <generated>ALWAYS</generated>
            </basic>
            <basic name="modifiedDate">
                <column name="modified_date" insertable="false" updatable="false"/>
                <temporal>TIMESTAMP</temporal>
                <generated>ALWAYS</generated>
            </basic>
            <basic name="dirty"/>
            <basic name="decodeAttempts">
                <column name="decode_attempts"/>
            </basic>
            <basic name="year">
                <column name="year_value"/>
            </basic>
            <basic name="msrp">
                <column name="msrp_value"/>
            </basic>
            <basic name="residualValue">
                <column name="residual_value"/>
            </basic>
            <basic name="invoicePrice">
                <column name="invoice_price"/>
            </basic>
            <basic name="odometer"/>
            <basic name="sequenceNumber">
                <column name="seq_number"/>
            </basic>
            <version name="version"/>
            <transient name="vin"/>
            <transient name="model"/>
            <transient name="modelDetail"/>
            <transient name="license"/>
            <transient name="status"/>
            <transient name="vehicleType"/>
            <transient name="classification"/>
            <transient name="country"/>
            <transient name="engineType"/>
            <transient name="assemblyPlant"/>
            <transient name="bodyType"/>
            <transient name="fuelType"/>
            <transient name="driveLineType"/>
            <many-to-one name="contract"
                         target-entity="org.hibernate.orm.test.query.hhh12225.VehicleContract">
                <join-column name="contract_id"/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
