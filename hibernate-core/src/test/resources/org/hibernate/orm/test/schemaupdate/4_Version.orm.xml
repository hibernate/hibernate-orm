<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
	<package>org.hibernate.orm.test.schemaupdate</package>

	<entity class="Version">
		<attributes>
			<id name="id">
				<generated-value strategy="SEQUENCE"/>
			</id>
			<basic name="description">
				<column length="500"/>
			</basic>
			<basic name="versionNumber">
				<target>java.lang.Long</target>
			</basic>
		</attributes>
	</entity>
</entity-mappings>
