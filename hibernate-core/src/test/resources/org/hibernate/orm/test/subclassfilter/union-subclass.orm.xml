<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <package>org.hibernate.orm.test.subclassfilter</package>

    <filter-def name="region">
        <filter-param name="userRegion" type="string"/>
    </filter-def>

    <entity class="Person" metadata-complete="true" access="PROPERTY">
        <table name="UPerson"/>
        <inheritance strategy="TABLE_PER_CLASS"/>
        <filter name="region">
            <condition>p_region = :userRegion</condition>
        </filter>
        <attributes>
            <id name="id">
                <column name="person_id"/>
                <generated-value generator="id-generator"/>
                <generic-generator name="id-generator" class="increment"/>
            </id>
            <basic name="name" optional="false"/>
            <basic name="company"/>
            <basic name="region">
                <column name="p_region"/>
            </basic>
        </attributes>
    </entity>

    <entity class="Employee" metadata-complete="true">
        <extends>org.hibernate.orm.test.subclassfilter.Person</extends>
        <table name="UEmployee"/>
        <attributes>
            <basic name="title">
                <column name="emp_title"/>
            </basic>
            <basic name="department">
                <column name="dept"/>
            </basic>
            <many-to-one name="manager" target-entity="Employee">
                <join-column name="mgr_id"/>
                <cascade/>
            </many-to-one>
            <one-to-many name="minions" target-entity="Employee" mapped-by="manager" classification="SET">
                <filter name="region">
                    <condition>p_region = :userRegion</condition>
                </filter>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-many>
        </attributes>
    </entity>

    <entity class="Customer" metadata-complete="true">
        <extends>org.hibernate.orm.test.subclassfilter.Person</extends>
        <table name="UCustomer"/>
        <attributes>
            <many-to-one name="contactOwner" target-entity="Employee">
                <join-column name="contactOwner"/>
                <cascade/>
            </many-to-one>
        </attributes>
    </entity>

</entity-mappings>
