<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.unconstrained.Person"
            access="FIELD" metadata-complete="true">
        <dynamic-update>true</dynamic-update>
        <attributes>
            <id name="name"/>
            <basic name="employeeId">
                <column name="employeeId" unique="true"/>
            </basic>
            <many-to-one name="employee"
                         target-entity="org.hibernate.orm.test.unconstrained.Employee"
                         not-found="IGNORE">
                <join-formula>employeeId</join-formula>
                <cascade>
                    <cascade-all/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.unconstrained.Employee"
            access="FIELD" metadata-complete="true">
        <attributes>
            <id name="id"/>
        </attributes>
    </entity>

</entity-mappings>
