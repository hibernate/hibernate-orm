<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.xml.index</package>
    <attribute-accessor>property</attribute-accessor>
    <default-cascade>none</default-cascade>
    <default-lazy>true</default-lazy>
    <entity class="PersonGroup" metadata-complete="true">
        <table name="PersonGroup"/>
        <dynamic-insert>false</dynamic-insert>
        <dynamic-update>false</dynamic-update>
        <select-before-update>false</select-before-update>
        <batch-size>-1</batch-size>
        <mutable>true</mutable>
        <optimistic-locking>VERSION</optimistic-locking>
        <attributes>
            <id name="id">
                <column name="id" unique="false" nullable="false" insertable="true" updatable="false"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="native"/>
                <java-type>org.hibernate.type.descriptor.java.LongJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <element-collection name="persons" target-class="java.lang.String" fetch="LAZY" optimistic-lock="true" classification="SET">
                <mutable>true</mutable>
                <column name="name" unique="false" nullable="false" insertable="true" updatable="true"/>
                <java-type>org.hibernate.type.descriptor.java.StringJavaType</java-type>
                <jdbc-type>org.hibernate.type.descriptor.jdbc.VarcharJdbcType</jdbc-type>
                <collection-table name="person">
                    <join-column name="group" unique="false" nullable="true" insertable="true" updatable="true"/>
                    <foreign-key name="person_persongroup_fk"/>
                </collection-table>
            </element-collection>
            <transient name="comments"/>
            <transient name="name"/>
        </attributes>
    </entity>
</entity-mappings>
