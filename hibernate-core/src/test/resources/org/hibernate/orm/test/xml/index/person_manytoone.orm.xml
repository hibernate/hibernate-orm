                <jdbc-type>org.hibernate.type.descriptor.jdbc.BigIntJdbcType</jdbc-type>
            </id>
            <many-to-one name="personGroup" target-entity="PersonGroup" fetch="LAZY" fetch-mode="SELECT" optional="true" not-found="EXCEPTION">
                <join-column name="personGroup" unique="false" nullable="true" insertable="true" updatable="true"/>
                <foreign-key name="person_persongroup_fk"/>
