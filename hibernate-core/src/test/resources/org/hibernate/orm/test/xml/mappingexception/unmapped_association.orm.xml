<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping" version="8.0">
    <package>org.hibernate.orm.test.xml.mappingexception</package>
    <attribute-accessor>property</attribute-accessor>
    <entity class="Person" metadata-complete="true">
        <attributes>
            <id name="id">
                <column name="PERSON_ID"/>
                <generated-value generator="id-id-generator"/>
                <generic-generator name="id-id-generator" class="increment"/>
            </id>
            <basic name="name">
                <column name="PERSON_NAME"/>
            </basic>
            <!-- UnmappedClass has no mapping — should cause MappingException -->
            <many-to-one name="unmapped" target-entity="UnmappedClass">
                <join-column name="UNMAPPED_ID"/>
            </many-to-one>
        </attributes>
    </entity>
</entity-mappings>
