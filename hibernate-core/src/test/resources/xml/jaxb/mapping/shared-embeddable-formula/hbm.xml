<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="org.hibernate.orm.test.boot.jaxb.mapping">

    <class name="FormulaUser" table="T_USER">
        <id name="userName"/>
        <component name="person">
            <property name="name" not-null="true"/>
            <property name="dob" not-null="true"/>
            <property name="yob" formula="year(dob)"/>
            <property name="heightInches">
                <column name="height_centimeters"
                    not-null="true"
                    read="height_centimeters / 2.54E0"
                    write="? * 2.54E0"/>
            </property>
        </component>
    </class>

    <class name="FormulaEmployee" table="T_EMP">
        <id name="id" type="long">
            <generator class="increment"/>
        </id>
        <component name="person">
            <property name="name" not-null="true"/>
            <property name="dob" not-null="true"/>
            <property name="yob"/>
            <property name="heightInches"/>
        </component>
    </class>

</hibernate-mapping>
