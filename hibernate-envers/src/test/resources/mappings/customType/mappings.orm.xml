<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.envers.entities.customtype.UnspecifiedEnumTypeEntity"
            access="PROPERTY">
        <table name="ENUM_ENTITY"/>
        <attributes>
            <id name="id">
                <column name="ID"/>
                <generated-value generator="increment"/>
                <generic-generator name="increment" class="increment"/>
            </id>
            <basic name="enum1">
                <type value="org.hibernate.orm.test.envers.integration.customtype.EnumType">
                    <parameters name="enumClass"
                                value="org.hibernate.orm.test.envers.entities.customtype.UnspecifiedEnumTypeEntity$E1"/>
                </type>
            </basic>
            <basic name="enum2">
                <type value="org.hibernate.orm.test.envers.integration.customtype.EnumType">
                    <parameters name="enumClass"
                                value="org.hibernate.orm.test.envers.entities.customtype.UnspecifiedEnumTypeEntity$E2"/>
                </type>
            </basic>
        </attributes>
    </entity>

</entity-mappings>
