<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 version="8.0">

    <entity class="org.hibernate.orm.test.envers.entities.onetoone.BidirectionalEagerHbmRefIngPK"
            access="PROPERTY">
        <table name="REFERENCING"/>
        <lazy>false</lazy>
        <attributes>
            <id name="id">
                <column name="REFERENCING_ID"/>
                <generated-value/>
            </id>
            <basic name="data"/>
            <many-to-one name="reference"
                         target-entity="org.hibernate.orm.test.envers.entities.onetoone.BidirectionalEagerHbmRefEdPK"
                         fetch="EAGER">
                <join-column name="BIDIRECTIONAL_REFERENCED_ID"/>
                <cascade>
                    <cascade-merge/>
                    <cascade-persist/>
                </cascade>
            </many-to-one>
        </attributes>
    </entity>

    <entity class="org.hibernate.orm.test.envers.entities.onetoone.BidirectionalEagerHbmRefEdPK"
            access="PROPERTY">
        <table name="REFERENCED_ENTITY"/>
        <lazy>false</lazy>
        <attributes>
            <id name="id">
                <column name="REFERENCED_ID"/>
                <generated-value/>
            </id>
            <basic name="data"/>
            <transient name="referencing"/>
        </attributes>
    </entity>

</entity-mappings>
