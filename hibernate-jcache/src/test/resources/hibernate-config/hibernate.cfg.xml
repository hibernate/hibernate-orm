<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>

    <session-factory>

        <!-- Enable Hibernate's automatic session context management -->
        <property name="current_session_context_class">thread</property>

        <property name="cache.use_query_cache">true</property>
        <property name="cache.use_second_level_cache">true</property>
        <property name="cache.use_structured_entries">true</property>
        <property name="cache.region.factory_class">jcache</property>
        <property name="net.sf.ehcache.configurationResourceName">/hibernate-config/ehcache.xml</property>
        <!-- Echo all executed SQL to stdout -->
        <property name="show_sql">true</property>

        <mapping class="org.hibernate.orm.test.jcache.domain.Event"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.Person"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.PhoneNumber"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.Account"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.HolidayCalendar"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.Item"/>
        <mapping class="org.hibernate.orm.test.jcache.domain.VersionedItem"/>

    </session-factory>

</hibernate-configuration>
